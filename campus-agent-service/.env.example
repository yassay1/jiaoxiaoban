# ============================================================
# campus-agent-service 环境变量模板
# 复制为 .env 后填入实际值
# ============================================================

# ---- LLM 配置 ----
LLM_PROVIDER=
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL_NAME=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=campus_agent
POSTGRES_USER=campus_agent
POSTGRES_PASSWORD=campus_agent_dev

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- 社区服务 (mock | local | real) ----
COMMUNITY_SERVICE_BASE_URL=http://localhost:8080/api
COMMUNITY_SERVICE_API_KEY=
COMMUNITY_SERVICE_MODE=local

# ---- Agent Service ----
AGENT_SERVICE_HOST=0.0.0.0
AGENT_SERVICE_PORT=8000
AGENT_SERVICE_DEBUG=false
DEMO_MODE=false

